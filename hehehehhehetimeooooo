                    fontSize: 11,
                    color: "#00d2ff",
                    fontWeight: 600,
                    display: "block",
                    marginBottom: 4,
                  }}
                >
                  Agent IA
                </span>
              )}
              {formatMessage(msg.content)}
            </div>
          </div>
        ))}

        {/* Loading indicator */}
        {loading && (
          <div style={{ display: "flex", justifyContent: "flex-start" }}>
            <div
              style={{
                padding: "12px 16px",
                borderRadius: "18px 18px 18px 4px",
                background: "rgba(255,255,255,0.06)",
                border: "1px solid rgba(255,255,255,0.08)",
                fontSize: 14,
              }}
            >
              <span
                style={{
                  fontSize: 11,
                  color: "#00d2ff",
                  fontWeight: 600,
                  display: "block",
                  marginBottom: 4,
                }}
              >
                Agent IA
              </span>
              <span style={{ color: "#888" }}>
                Traitement en cours
                <LoadingDots />
              </span>
            </div>
          </div>
        )}
      </div>

      {/* Input */}
      <div
        style={{
          width: "100%",
          maxWidth: 720,
          padding: "12px 16px 24px",
        }}
      >
        <form
          onSubmit={handleSubmit}
          style={{
            display: "flex",
            gap: 8,
            background: "rgba(255,255,255,0.05)",
            borderRadius: 24,
            padding: 4,
            border: "1px solid rgba(255,255,255,0.1)",
          }}
        >
          <input
            type="text"
            value={input}
            onChange={(e) => setInput(e.target.value)}
            placeholder="Ex: Achète-moi le t-shirt noir..."
            disabled={loading}
            style={{
              flex: 1,
              border: "none",
              background: "transparent",
              padding: "12px 16px",
              fontSize: 14,
              color: "#e0e0e0",
              outline: "none",
            }}
          />
          <button
            type="submit"
            disabled={loading || !input.trim()}
            style={{
              background:
                loading || !input.trim()
                  ? "rgba(123,47,247,0.3)"
                  : "linear-gradient(135deg, #7b2ff7, #00d2ff)",
              border: "none",
              borderRadius: 20,
              padding: "10px 20px",
              color: "#fff",
              fontWeight: 600,
              fontSize: 14,
              cursor: loading || !input.trim() ? "not-allowed" : "pointer",
              transition: "all 0.2s",
            }}
          >
            {loading ? "..." : "Envoyer"}
          </button>
        </form>
      </div>
    </div>
  );
}

// --- Helpers ---

/** Met en gras les textes entre ** et formate les hash de transaction */
function formatMessage(text: string) {
  // Détecte les hash de transaction TON (base64url-like, 44+ chars)
  const parts = text.split(
    /(\b[A-Za-z0-9_-]{43,}={0,2}\b|`[^`]+`|\*\*[^*]+\*\*)/g
  );

  return parts.map((part, i) => {
    if (part.startsWith("**") && part.endsWith("**")) {
      return (
        <strong key={i} style={{ color: "#fff" }}>
          {part.slice(2, -2)}
        </strong>
      );
    }
    if (part.startsWith("`") && part.endsWith("`")) {
      return (
        <code
          key={i}
          style={{
            background: "rgba(123,47,247,0.2)",
            padding: "2px 6px",
            borderRadius: 4,
            fontSize: 12,
            fontFamily: "monospace",
            color: "#c4a5ff",
            wordBreak: "break-all",
          }}
        >
          {part.slice(1, -1)}
        </code>
      );
    }
    return part;
  });
}

function LoadingDots() {
  const [dots, setDots] = useState("");

  useEffect(() => {
    const id = setInterval(() => {
      setDots((d) => (d.length >= 3 ? "" : d + "."));
    }, 400);
    return () => clearInterval(id);
  }, []);

  return <span>{dots}</span>;
}

























































